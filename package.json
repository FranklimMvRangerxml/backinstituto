  "description": "Monorepo con microservicios",
  "type": "module",
  "private": true,
  "scripts": {
   "start": "node gateway/server.js",
  "dev:gateway": "nodemon gateway/server.js",
  "dev:auth": "nodemon services/auth-service/server.js",
