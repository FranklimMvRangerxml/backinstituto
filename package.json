    "express": "^5.2.1",
    "express-http-proxy": "^2.1.2",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
